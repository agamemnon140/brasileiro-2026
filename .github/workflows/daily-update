name: Atualizar Resultados (Claude + Web Search)

on:
  schedule:
    # Todo dia às 08:00 UTC (05:00 BRT) — após os jogos do dia anterior
    - cron: '0 8 * * *'
  workflow_dispatch:
    inputs:
      date:
        description: 'Data dos jogos (YYYY-MM-DD). Vazio = ontem.'
        required: false

permissions:
  contents: write

jobs:
  update:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Instalar dependências
        run: pip install requests

      - name: Buscar resultados via Claude
        env:
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
        run: |
          if [ -n "${{ github.event.inputs.date }}" ]; then
            python update_results.py "${{ github.event.inputs.date }}"
          else
            python update_results.py
          fi

      - name: Commit e push
        run: |
          git config user.name "Brasileirão Bot"
          git config user.email "bot@users.noreply.github.com"
          git add index.html
          if git diff --cached --quiet; then
            echo "Sem mudanças."
          else
            ONTEM=$(date -u -d '-1 day' +%d/%m/%Y)
            git commit -m "⚽ Resultados: ${ONTEM}"
            git push
          fi
